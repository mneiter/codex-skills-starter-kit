{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillMetadata",
  "type": "object",
  "required": [
    "name",
    "layer",
    "purpose",
    "triggers",
    "inputs",
    "outputs",
    "dependencies",
    "verification"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "layer": {
      "type": "string",
      "enum": [
        "atomic",
        "guardrails",
        "orchestration"
      ]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
